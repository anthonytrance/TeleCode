TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
# Optional safety labels for canary and production launches.
# Leave unset for current local development behavior.
# Legacy TELECODEX_* forms remain accepted for existing installations.
TELECODE_TOKEN_ROLE=
TELECODE_CANARY_MODE=false
TELECODE_ALLOW_PRODUCTION_POLLING=false
CODEX_API_KEY=
CODEX_MODEL=
CODEX_BACKEND=app-server
# Optional absolute path to the Codex binary used by /appserver.
CODEX_APP_SERVER_PATH=
MAX_FILE_SIZE=20971520
CODEX_SANDBOX_MODE=workspace-write
CODEX_APPROVAL_POLICY=never
# Optional extra profiles for /launch_profiles, e.g. [{"id":"review","label":"Review","sandboxMode":"workspace-write","approvalPolicy":"on-request"}]
CODEX_LAUNCH_PROFILES_JSON=
CODEX_DEFAULT_LAUNCH_PROFILE=default
# Set to true to expose the built-in Full Access profile and allow extra danger-full-access profiles.
ENABLE_UNSAFE_LAUNCH_PROFILES=false
TOOL_VERBOSITY=summary
STREAM_ASSISTANT_TEXT=false
PROGRESS_DELIVERY=messages
SHOW_TURN_TOKEN_USAGE=false
ENABLE_TELEGRAM_LOGIN=true
ENABLE_TELEGRAM_REACTIONS=false
ENABLE_CLAUDE_PROVIDER=false
# Optional absolute path to the Claude Code binary. When unset, TeleCode uses
# ~/.local/bin/claude(.exe) if present, otherwise resolves `claude` from PATH.
CLAUDE_BIN=
CLAUDE_DEFAULT_MODEL=sonnet
CLAUDE_WORKSPACE=
CLAUDE_PERMISSION_MODE=acceptEdits
CLAUDE_TURN_IDLE_TIMEOUT=180
CLAUDE_CONTEXT_WINDOW=200000
# Default Claude engine for contexts that never ran /backend.
# sdk = Claude Agent SDK: structured events and full progress narration.
# pty = interactive Claude Code terminal driven over a pseudo-terminal.
# Per-context /backend choices override this and persist across restarts.
CLAUDE_BACKEND=pty
OPENAI_API_KEY=
