{
  "name": "telecodeide",
  "version": "0.1.0",
  "description": "Provider-aware Telegram interface for OpenAI Codex and Claude Code",
  "license": "MIT",
  "author": "Benedict Evert and TeleCode contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthonytrance/TeleCode"
  },
  "keywords": [
    "telegram",
    "codex",
    "claude",
    "multi-provider",
    "openai",
    "bot",
    "cli",
    "bridge"
  ],
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:claude-smoke": "npm run build && node scripts/claude-provider-smoke.mjs",
    "test:claude-tool-smoke": "npm run build && node scripts/claude-tool-smoke.mjs",
    "test:claude-bot-smoke": "npm run build && node scripts/claude-bot-flow-smoke.mjs",
    "test:claude-sdk-smoke": "npm run build && node scripts/claude-sdk-bot-flow-smoke.mjs",
    "test:claude-live": "npm run build && node scripts/claude-provider-smoke.mjs && node scripts/claude-tool-smoke.mjs && node scripts/claude-bot-flow-smoke.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.204",
    "@grammyjs/auto-retry": "^2.0.2",
    "@openai/codex-sdk": "0.144.1",
    "grammy": "^1.41.1",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.5.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0",
    "parakeet-coreml": "^2.2.0"
  }
}
